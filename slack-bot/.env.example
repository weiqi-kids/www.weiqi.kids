# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-你的-bot-token

# Slack App Token (xapp-...)
SLACK_APP_TOKEN=xapp-你的-app-token

# 允許的 Slack 頻道 ID (C...)
SLACK_CHANNEL_ID=C開頭的頻道ID

# 專案路徑
PROJECT_PATH=/home/YOUR_USER/www.weiqi.kids

# 允許使用 Bot 的 Slack 使用者 ID（逗號分隔）
# 留空表示允許所有人
ALLOWED_USERS=U12345,U67890
